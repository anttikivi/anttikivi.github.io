{
  "name": "anttikivi.fi",
  "private": true,
  "version": "0.12.0-dev",
  "description": "Antti Kivi's website",
  "scripts": {
    "build": "gatsby build",
    "check-all": "npm-run-all format --parallel lint:js lint:css",
    "ci-check": "npm-run-all nit --parallel lint:js lint:css",
    "dev": "gatsby develop",
    "format": "prettier --config .prettierrc.json --write \"**/*.{js,jsx,json,md}\"",
    "nit": "prettier --config .prettierrc.json --list-different \"**/*.{js,jsx,json,md}\"",
    "test": "jest",
    "lint:js": "eslint .",
    "lint:css": "stylelint './src/**/*{.js,jsx}'",
    "clean": "gatsby clean",
    "start": "yarn dev",
    "serve": "gatsby serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anttikivi/anttikivi.fi.git"
  },
  "author": "Antti Kivi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/anttikivi/anttikivi.fi/issues"
  },
  "homepage": "https://github.com/anttikivi/anttikivi.fi#readme",
  "dependencies": {
    "@primer/octicons-react": "^13.0.0",
    "@reach/router": "^1.3.4",
    "dotenv": "^8.2.0",
    "gatsby": "^3.2.1",
    "gatsby-plugin-catch-links": "^3.2.0",
    "gatsby-plugin-google-gtag": "^3.2.0",
    "gatsby-plugin-google-tagmanager": "^3.2.0",
    "gatsby-plugin-i18n": "^1.0.1",
    "gatsby-plugin-image": "^1.1.2",
    "gatsby-plugin-manifest": "^3.2.0",
    "gatsby-plugin-netlify": "^3.2.0",
    "gatsby-plugin-react-helmet": "^4.2.0",
    "gatsby-plugin-sharp": "^3.2.1",
    "gatsby-plugin-sitemap": "^3.2.0",
    "gatsby-plugin-styled-components": "^4.2.0",
    "gatsby-source-contentful": "^5.2.1",
    "gatsby-source-filesystem": "^3.3.0",
    "gatsby-transformer-json": "^3.2.0",
    "gatsby-transformer-remark": "^4.0.0",
    "gatsby-transformer-sharp": "^3.2.0",
    "normalize.css": "^8.0.1",
    "prop-types": "^15.7.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-helmet": "^6.1.0",
    "react-intl": "^5.15.8",
    "react-is": "^17.0.2",
    "scroll-to-element": "^2.0.3",
    "styled-components": "^5.2.3",
    "terser": "4.8.0",
    "universal-cookie": "^4.0.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.11.10",
    "@testing-library/react": "^11.2.6",
    "@testing-library/user-event": "^13.1.3",
    "babel-jest": "^26.6.3",
    "babel-plugin-styled-components": "^1.12.0",
    "babel-preset-gatsby": "^1.3.0",
    "eslint": "^7.24.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^8.1.0",
    "eslint-import-resolver-node": "^0.3.4",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^24.3.5",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.23.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^26.6.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.2.1",
    "react-test-renderer": "^17.0.2",
    "stylelint": "^13.12.0",
    "stylelint-config-recommended": "^4.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-processor-styled-components": "^1.10.0"
  }
}
