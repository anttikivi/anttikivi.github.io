{
  "name": "anttikivi.github.io",
  "private": true,
  "version": "0.5.0",
  "description": "Antti Kivi's website",
  "scripts": {
    "build": "yarn clean && gatsby build",
    "check-all": "npm-run-all format --parallel lint:scss lint:js",
    "ci-check": "npm-run-all nit --parallel lint:scss lint:js",
    "dev": "gatsby develop",
    "format": "prettier --config .prettierrc.json --write \"**/*.{js,jsx,json,md}\"",
    "nit": "prettier --config .prettierrc.json --list-different \"**/*.{js,jsx,json,md}\"",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\"",
    "lint:scss": "stylelint '**/*.scss'",
    "lint:js": "eslint 'src/**/*.js' 'src/**/*.jsx'",
    "clean": "gatsby clean && rm -rf src/__generated__",
    "start": "yarn dev",
    "serve": "gatsby serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anttikivi/anttikivi.github.io.git"
  },
  "author": "Antti Kivi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/anttikivi/anttikivi.github.io/issues"
  },
  "homepage": "https://github.com/anttikivi/anttikivi.github.io#readme",
  "dependencies": {
    "autoprefixer": "^10.0.1",
    "gatsby": "^2.27.0",
    "gatsby-image": "^2.4.21",
    "gatsby-plugin-canonical-urls": "^2.3.13",
    "gatsby-plugin-google-analytics": "^2.3.19",
    "gatsby-plugin-i18n": "^1.0.1",
    "gatsby-plugin-manifest": "^2.4.37",
    "gatsby-plugin-postcss": "^3.0.4",
    "gatsby-plugin-react-helmet": "^3.3.14",
    "gatsby-plugin-sass": "^2.3.22",
    "gatsby-plugin-sitemap": "^2.4.17",
    "gatsby-source-filesystem": "^2.3.37",
    "gatsby-transformer-remark": "^2.8.47",
    "node-sass": "^4.14.1",
    "postcss": "^8.1.4",
    "prop-types": "^15.7.2",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-helmet": "^6.1.0",
    "react-intl": "^5.8.8"
  },
  "devDependencies": {
    "eslint": "^7.12.1",
    "eslint-plugin-react": "^7.21.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.1.2",
    "stylelint": "^13.7.2",
    "stylelint-config-recommended-scss": "^4.2.0",
    "stylelint-scss": "^3.18.0"
  }
}
